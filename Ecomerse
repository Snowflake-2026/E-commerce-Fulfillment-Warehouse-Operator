GRANT USAGE ON DATABASE ecommerce_db TO ROLE ADMIN_ROLE;
GRANT USAGE ON DATABASE ecommerce_db TO ROLE MANAGER_ROLE;
GRANT USAGE ON DATABASE ecommerce_db TO ROLE QC_ROLE;
GRANT USAGE ON DATABASE ecommerce_db TO ROLE WORKER_ROLE;

GRANT USAGE ON ALL SCHEMAS IN DATABASE ecommerce_db TO ROLE ADMIN_ROLE;
GRANT USAGE ON ALL SCHEMAS IN DATABASE ecommerce_db TO ROLE MANAGER_ROLE;
GRANT USAGE ON ALL SCHEMAS IN DATABASE ecommerce_db TO ROLE QC_ROLE;
GRANT USAGE ON ALL SCHEMAS IN DATABASE ecommerce_db TO ROLE WORKER_ROLE;

GRANT ALL PRIVILEGES ON ALL TABLES IN DATABASE ecommerce_db TO ROLE ADMIN_ROLE;

GRANT SELECT ON ALL TABLES IN DATABASE ecommerce_db TO ROLE MANAGER_ROLE;

GRANT SELECT ON validated.events_validated TO ROLE QC_ROLE;
GRANT SELECT ON curated.fact_events TO ROLE QC_ROLE;

GRANT SELECT ON validated.events_validated TO ROLE WORKER_ROLE;
GRANT SELECT ON curated.fact_orders TO ROLE WORKER_ROLE;

CREATE OR REPLACE ROW ACCESS POLICY event_policy
AS (event_type STRING)
RETURNS BOOLEAN ->
CASE
    WHEN CURRENT_ROLE() = 'ADMIN_ROLE' THEN TRUE
    WHEN CURRENT_ROLE() = 'MANAGER_ROLE' THEN TRUE
    WHEN CURRENT_ROLE() = 'QC_ROLE' AND event_type = 'qc' THEN TRUE
    WHEN CURRENT_ROLE() = 'WORKER_ROLE' AND event_type IN ('pick','pack') THEN TRUE
    ELSE FALSE
END;

ALTER TABLE validated.events_validated
ADD ROW ACCESS POLICY event_policy ON (event_type);

