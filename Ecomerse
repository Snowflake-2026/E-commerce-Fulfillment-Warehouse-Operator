SELECT 
    employee_id,
    COUNT(*) AS total_events
FROM curated.fact_events
GROUP BY employee_id;

SELECT * FROM curated.kpi_employee_productivity;
-----------------------------------------------------ORDER FLOW COMPLETION-----------------------------------------------------
CREATE OR REPLACE TABLE curated.kpi_order_flow AS
SELECT 
    COUNT(DISTINCT order_id) AS total_orders,

    COUNT(DISTINCT CASE 
        WHEN event_type = 'ship' 
    THEN order_id END) AS completed_orders,

    ROUND(
        COUNT(DISTINCT CASE 
            WHEN event_type = 'ship' 
        THEN order_id END)
        / COUNT(DISTINCT order_id) * 100,
    2) AS completion_rate

FROM curated.fact_events;

SELECT * FROM curated.kpi_order_flow;

