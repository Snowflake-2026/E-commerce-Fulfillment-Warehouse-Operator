---------------------------ANOMALY---------------
CREATE OR REPLACE TABLE curated.order_anomalies (
    anomaly_id INT AUTOINCREMENT,
    order_id INT,
    anomaly_type STRING,
    reason STRING,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
CREATE OR REPLACE PROCEDURE curated.sp_detect_anomalies()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN

---------------------------------------------------
-- 1. SLA BREACH
---------------------------------------------------
INSERT INTO curated.order_anomalies (order_id, anomaly_type, reason)
SELECT order_id,
       'SLA_BREACH',
       'Order not shipped on time'
FROM validated.orders_validated
WHERE status != 'shipped';

---------------------------------------------------
-- 2. QC FAILURE / MIS PICK
---------------------------------------------------
INSERT INTO curated.order_anomalies (order_id, anomaly_type, reason)
SELECT order_id,
       'QC_FAILURE',
       'QC failed'
FROM validated.events_validated
WHERE event_type = 'qc'
AND remarks ILIKE '%fail%';

---------------------------------------------------
-- 3. EVENT SEQUENCE ERROR
---------------------------------------------------
INSERT INTO curated.order_anomalies (order_id, anomaly_type, reason)
SELECT order_id,
       'SEQUENCE_ERROR',
       'Wrong event flow'
FROM (
    SELECT order_id,
           LISTAGG(event_type, '->') 
           WITHIN GROUP (ORDER BY event_time) AS seq
    FROM validated.events_validated
    GROUP BY order_id
)
WHERE seq NOT LIKE 'pick->pack->qc->ship%';

---------------------------------------------------
-- 4. INVENTORY ISSUE
---------------------------------------------------
INSERT INTO curated.order_anomalies (order_id, anomaly_type, reason)
SELECT NULL,
       'INVENTORY_ISSUE',
       'Stock mismatch'
FROM validated.inventory_validated
WHERE reserved_qty > on_hand_qty;

RETURN 'ANOMALY DETECTED';

END;
$$;

CALL curated.sp_detect_anomalies();

CREATE OR REPLACE TASK curated.anomaly_task
WAREHOUSE = compute_wh
AFTER curated.scd_task
AS
CALL curated.sp_detect_anomalies();

