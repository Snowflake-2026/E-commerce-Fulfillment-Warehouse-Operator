CREATE OR REPLACE MASKING POLICY mask_email
AS (val STRING)
RETURNS STRING ->
CASE
    WHEN CURRENT_ROLE() IN ('ACCOUNTADMIN') THEN val
    ELSE '****@' || SPLIT_PART(val, '@', 2)
END;

CREATE OR REPLACE MASKING POLICY mask_phone
AS (val STRING)
RETURNS STRING ->
CASE
    WHEN CURRENT_ROLE() IN ('ACCOUNTADMIN','SECURITYADMIN') THEN val
    ELSE '+91XXXXXX' || RIGHT(val, 4)
END;

