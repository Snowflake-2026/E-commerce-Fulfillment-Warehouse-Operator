CREATE DATABASE ecommerce_db;
USE DATABASE ecommerce_db;
--------------------------------------RAW LAYER---------------------------
CREATE SCHEMA raw;

-- FILE FORMAT
CREATE OR REPLACE FILE FORMAT csv_format
TYPE = 'CSV'
FIELD_OPTIONALLY_ENCLOSED_BY = '"'
SKIP_HEADER = 1;

-- STAGE
CREATE OR REPLACE STAGE my_stage
FILE_FORMAT = csv_format;

-- TABLES
CREATE OR REPLACE TABLE raw.orders_raw (
    order_id INT, customer_id INT, order_date DATE,
    promised_ship_date DATE, order_value FLOAT,
    item_count INT, order_channel STRING,
    priority_flag STRING, status STRING
);

CREATE OR REPLACE TABLE raw.customers_raw (
    customer_id INT, customer_name STRING,
    email STRING, phone STRING,
    city STRING, state STRING,
    segment STRING, registration_date DATE
);

CREATE OR REPLACE TABLE raw.employees_raw (
    employee_id INT, name STRING, role STRING,
    shift_start DATE, shift_end DATE,
    hub_id INT, join_date DATE, status STRING
);

CREATE OR REPLACE TABLE raw.inventory_raw (
    inventory_id INT, sku_id INT, sku_name STRING,
    category STRING, on_hand_qty INT,
    reserved_qty INT, reorder_level INT,
    last_restock_date DATE, warehouse_id INT
);

CREATE OR REPLACE TABLE raw.events_raw (
    event_id INT, order_id INT, employee_id INT,
    event_type STRING, event_time TIMESTAMP, remarks STRING
);

-- LOAD DATA
CREATE OR REPLACE PIPE raw.orders_pipe AS
COPY INTO raw.orders_raw
FROM @my_stage
FILE_FORMAT = csv_format
PATTERN = '.*orders_.*.csv';

CREATE OR REPLACE PIPE raw.customers_pipe AS
COPY INTO raw.customers_raw
FROM @my_stage
FILE_FORMAT = csv_format
PATTERN = '.*customers_.*.csv';

CREATE OR REPLACE PIPE raw.employees_pipe AS
COPY INTO raw.employees_raw
FROM @my_stage
FILE_FORMAT = csv_format
PATTERN = '.*employees_.*.csv';

CREATE OR REPLACE PIPE raw.inventory_pipe AS
COPY INTO raw.inventory_raw
FROM @my_stage
FILE_FORMAT = csv_format
PATTERN = '.*inventory_.*.csv';

CREATE OR REPLACE PIPE raw.events_pipe AS
COPY INTO raw.events_raw
FROM @my_stage
FILE_FORMAT = csv_format
PATTERN = '.*events_.*.csv';

----------------------------VALIDATED LAYER-------------------------------
CREATE SCHEMA validated;

-- STREAMS
CREATE STREAM raw.orders_stream ON TABLE raw.orders_raw;
CREATE STREAM raw.customers_stream ON TABLE raw.customers_raw;
CREATE STREAM raw.employees_stream ON TABLE raw.employees_raw;
CREATE STREAM raw.inventory_stream ON TABLE raw.inventory_raw;
CREATE STREAM raw.events_stream ON TABLE raw.events_raw;

-- VALID TABLES
CREATE OR REPLACE TABLE validated.orders_validated AS
SELECT * FROM raw.orders_raw;

CREATE OR REPLACE TABLE validated.customers_validated AS
SELECT * FROM raw.customers_raw;

CREATE OR REPLACE TABLE validated.employees_validated AS
SELECT * FROM raw.employees_raw;

CREATE OR REPLACE TABLE validated.inventory_validated AS
SELECT * FROM raw.inventory_raw;

CREATE OR REPLACE TABLE validated.events_validated AS
SELECT * FROM raw.events_raw;

CREATE OR REPLACE TABLE validated.orders_error LIKE validated.orders_validated;
CREATE OR REPLACE TABLE validated.customers_error LIKE validated.customers_validated;
CREATE OR REPLACE TABLE validated.employees_error LIKE validated.employees_validated;
CREATE OR REPLACE TABLE validated.inventory_error LIKE validated.inventory_validated;
CREATE OR REPLACE TABLE validated.events_error LIKE validated.events_validated;

CREATE OR REPLACE PROCEDURE validated.sp_load_validated()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN

-- ORDERS
MERGE INTO validated.orders_validated tgt
USING raw.orders_stream src
ON tgt.order_id = src.order_id
WHEN MATCHED THEN UPDATE SET
    customer_id = src.customer_id,
    order_date = src.order_date,
    promised_ship_date = src.promised_ship_date,
    order_value = src.order_value,
    item_count = src.item_count,
    order_channel = src.order_channel,
    priority_flag = src.priority_flag,
    status = src.status
WHEN NOT MATCHED THEN INSERT VALUES (
    src.order_id, src.customer_id, src.order_date,
    src.promised_ship_date, src.order_value,
    src.item_count, src.order_channel,
    src.priority_flag, src.status
);

-- CUSTOMERS
MERGE INTO validated.customers_validated tgt
USING raw.customers_stream src
ON tgt.customer_id = src.customer_id
WHEN MATCHED THEN UPDATE SET
    customer_name = src.customer_name,
    email = src.email,
    phone = src.phone,
    city = src.city,
    state = src.state,
    segment = src.segment,
    registration_date = src.registration_date
WHEN NOT MATCHED THEN INSERT VALUES (
    src.customer_id, src.customer_name, src.email,
    src.phone, src.city, src.state,
    src.segment, src.registration_date
);

-- EMPLOYEES
MERGE INTO validated.employees_validated tgt
USING raw.employees_stream src
ON tgt.employee_id = src.employee_id
WHEN MATCHED THEN UPDATE SET
    name = src.name,
    role = src.role,
    shift_start = src.shift_start,
    shift_end = src.shift_end,
    hub_id = src.hub_id,
    join_date = src.join_date,
    status = src.status
WHEN NOT MATCHED THEN INSERT VALUES (
    src.employee_id, src.name, src.role,
    src.shift_start, src.shift_end,
    src.hub_id, src.join_date, src.status
);

-- INVENTORY
MERGE INTO validated.inventory_validated tgt
USING raw.inventory_stream src
ON tgt.inventory_id = src.inventory_id
WHEN MATCHED THEN UPDATE SET
    sku_id = src.sku_id,
    sku_name = src.sku_name,
    category = src.category,
    on_hand_qty = src.on_hand_qty,
    reserved_qty = src.reserved_qty,
    reorder_level = src.reorder_level,
    last_restock_date = src.last_restock_date,
    warehouse_id = src.warehouse_id
WHEN NOT MATCHED THEN INSERT VALUES (
    src.inventory_id, src.sku_id, src.sku_name,
    src.category, src.on_hand_qty,
    src.reserved_qty, src.reorder_level,
    src.last_restock_date, src.warehouse_id
);

-- EVENTS
MERGE INTO validated.events_validated tgt
USING raw.events_stream src
ON tgt.event_id = src.event_id
WHEN MATCHED THEN UPDATE SET
    order_id = src.order_id,
    employee_id = src.employee_id,
    event_type = src.event_type,
    event_time = src.event_time,
    remarks = src.remarks
WHEN NOT MATCHED THEN INSERT VALUES (
    src.event_id, src.order_id, src.employee_id,
    src.event_type, src.event_time, src.remarks
);

RETURN 'MERGE DONE';
END;
$$;

CREATE OR REPLACE PROCEDURE validated.sp_clean()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN

---------------------------------------------------
-- 1. ORDERS DQ
---------------------------------------------------

-- INVALID ORDERS → ERROR TABLE
INSERT INTO validated.orders_error
SELECT *
FROM validated.orders_validated
WHERE order_id IS NULL
   OR customer_id IS NULL
   OR order_value < 0
   OR item_count < 1
   OR promised_ship_date < order_date
   OR order_value > 100000;

-- DELETE INVALID
DELETE FROM validated.orders_validated
WHERE order_id IS NULL
   OR customer_id IS NULL
   OR order_value < 0
   OR item_count < 1
   OR promised_ship_date < order_date
   OR order_value > 100000;

---------------------------------------------------
-- REMOVE DUPLICATES (ORDERS)
---------------------------------------------------
DELETE FROM validated.orders_validated
WHERE order_id IN (
    SELECT order_id FROM (
        SELECT order_id,
               ROW_NUMBER() OVER (PARTITION BY order_id ORDER BY order_date DESC) rn
        FROM validated.orders_validated
    ) WHERE rn > 1
);

---------------------------------------------------
-- 2. CUSTOMERS DQ
---------------------------------------------------

INSERT INTO validated.customers_error
SELECT *
FROM validated.customers_validated
WHERE customer_id IS NULL
   OR email NOT LIKE '%@%';

DELETE FROM validated.customers_validated
WHERE customer_id IS NULL
   OR email NOT LIKE '%@%';

---------------------------------------------------
-- REMOVE DUPLICATES (CUSTOMERS)
---------------------------------------------------
DELETE FROM validated.customers_validated
WHERE customer_id IN (
    SELECT customer_id FROM (
        SELECT customer_id,
               ROW_NUMBER() OVER (PARTITION BY customer_id ORDER BY registration_date DESC) rn
        FROM validated.customers_validated
    ) WHERE rn > 1
);

---------------------------------------------------
-- 3. EMPLOYEES DQ
---------------------------------------------------

INSERT INTO validated.employees_error
SELECT *
FROM validated.employees_validated
WHERE employee_id IS NULL
   OR shift_start > shift_end;

DELETE FROM validated.employees_validated
WHERE employee_id IS NULL
   OR shift_start > shift_end;

---------------------------------------------------
-- REMOVE DUPLICATES (EMPLOYEES)
---------------------------------------------------
DELETE FROM validated.employees_validated
WHERE employee_id IN (
    SELECT employee_id FROM (
        SELECT employee_id,
               ROW_NUMBER() OVER (PARTITION BY employee_id ORDER BY join_date DESC) rn
        FROM validated.employees_validated
    ) WHERE rn > 1
);

---------------------------------------------------
-- 4. INVENTORY DQ
---------------------------------------------------

INSERT INTO validated.inventory_error
SELECT *
FROM validated.inventory_validated
WHERE on_hand_qty < 0
   OR reserved_qty < 0
   OR reserved_qty > on_hand_qty;

DELETE FROM validated.inventory_validated
WHERE on_hand_qty < 0
   OR reserved_qty < 0
   OR reserved_qty > on_hand_qty;

---------------------------------------------------
-- REMOVE DUPLICATES (SKU)
---------------------------------------------------
DELETE FROM validated.inventory_validated
WHERE sku_id IN (
    SELECT sku_id FROM (
        SELECT sku_id,
               ROW_NUMBER() OVER (PARTITION BY sku_id ORDER BY last_restock_date DESC) rn
        FROM validated.inventory_validated
    ) WHERE rn > 1
);

---------------------------------------------------
-- 5. EVENTS DQ
---------------------------------------------------

INSERT INTO validated.events_error
SELECT *
FROM validated.events_validated
WHERE event_type NOT IN ('pick','pack','qc','ship')
   OR event_time IS NULL;

DELETE FROM validated.events_validated
WHERE event_type NOT IN ('pick','pack','qc','ship')
   OR event_time IS NULL;

---------------------------------------------------
-- 6. REFERENTIAL INTEGRITY
---------------------------------------------------

-- EVENTS → ORDERS
DELETE FROM validated.events_validated
WHERE order_id NOT IN (
    SELECT order_id FROM validated.orders_validated
);

-- EVENTS → EMPLOYEES
DELETE FROM validated.events_validated
WHERE employee_id NOT IN (
    SELECT employee_id FROM validated.employees_validated
);

-- ORDERS → CUSTOMERS
DELETE FROM validated.orders_validated
WHERE customer_id NOT IN (
    SELECT customer_id FROM validated.customers_validated
);

---------------------------------------------------
-- 7. TEMPORAL VALIDATION
---------------------------------------------------

-- EVENT TIME SHOULD NOT BE FUTURE
DELETE FROM validated.events_validated
WHERE event_time > CURRENT_TIMESTAMP;

---------------------------------------------------
-- 8. DOMAIN VALIDATION
---------------------------------------------------

-- STATUS CHECK
DELETE FROM validated.orders_validated
WHERE status NOT IN ('created','processing','shipped','delivered','cancelled');

---------------------------------------------------
RETURN 'ALL DATA QUALITY CHECKS APPLIED';

END;
$$;

CALL validated.sp_clean();


SELECT 'orders' AS table_name, COUNT(*) FROM validated.orders_validated
UNION ALL
SELECT 'customers', COUNT(*) FROM validated.customers_validated
UNION ALL
SELECT 'employees', COUNT(*) FROM validated.employees_validated
UNION ALL
SELECT 'inventory', COUNT(*) FROM validated.inventory_validated
