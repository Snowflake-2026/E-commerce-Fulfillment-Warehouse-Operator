    COUNT(*) total_items,
    COUNT(CASE WHEN on_hand_qty >= reserved_qty THEN 1 END) available_items,
    ROUND(
        COUNT(CASE WHEN on_hand_qty >= reserved_qty THEN 1 END)
        / COUNT(*) * 100, 2
    ) availability_percentage
FROM validated.inventory_validated;

SELECT * FROM curated.kpi_inventory;
