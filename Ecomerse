SELECT 
    COUNT(*) total_orders,
    COUNT(CASE WHEN status='shipped' THEN 1 END) shipped_orders,
    ROUND(
        COUNT(CASE WHEN status='shipped' THEN 1 END) 
        / COUNT(*) * 100, 2
    ) AS sla_percentage
