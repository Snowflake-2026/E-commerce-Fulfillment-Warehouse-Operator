CREATE OR REPLACE PROCEDURE validated.sp_load_validated()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN

-- ORDERS
INSERT INTO validated.orders_validated
SELECT 
    order_id, customer_id, order_date, promised_ship_date,
    order_value, item_count, order_channel, priority_flag, status
FROM raw.orders_stream
WHERE METADATA$ACTION = 'INSERT';

-- CUSTOMERS
INSERT INTO validated.customers_validated
SELECT 
    customer_id, customer_name, email, phone,
    city, state, segment, registration_date
FROM raw.customers_stream
WHERE METADATA$ACTION = 'INSERT';

-- EMPLOYEES
INSERT INTO validated.employees_validated
SELECT 
    employee_id, name, role, shift_start,
    shift_end, hub_id, join_date, status
FROM raw.employees_stream
WHERE METADATA$ACTION = 'INSERT';

-- INVENTORY
INSERT INTO validated.inventory_validated
SELECT 
    inventory_id, sku_id, sku_name, category,
    on_hand_qty, reserved_qty, reorder_level,
    last_restock_date, warehouse_id
FROM raw.inventory_stream
WHERE METADATA$ACTION = 'INSERT';

-- EVENTS
INSERT INTO validated.events_validated
SELECT 
    event_id, order_id, employee_id,
    event_type, event_time, remarks
FROM raw.events_stream
WHERE METADATA$ACTION = 'INSERT';

RETURN 'DATA LOADED INTO VALIDATED';

END;
$$;

CALL validated.sp_load_validated();


CREATE OR REPLACE PROCEDURE validated.sp_clean_all()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN

---------------------------------------------------
-- ORDERS VALIDATION
---------------------------------------------------
DELETE FROM validated.orders_validated
WHERE order_id IS NULL
   OR order_value < 0
   OR item_count < 1
   OR promised_ship_date < order_date;

---------------------------------------------------
-- REMOVE DUPLICATES (ORDERS)
---------------------------------------------------
DELETE FROM validated.orders_validated
WHERE order_id IN (
    SELECT order_id FROM (
        SELECT order_id,
               ROW_NUMBER() OVER (PARTITION BY order_id ORDER BY order_date DESC) rn
        FROM validated.orders_validated
    ) WHERE rn > 1
);

---------------------------------------------------
-- CUSTOMERS
---------------------------------------------------
DELETE FROM validated.customers_validated
WHERE customer_id IS NULL;

---------------------------------------------------
-- EMPLOYEES
---------------------------------------------------
DELETE FROM validated.employees_validated
WHERE employee_id IS NULL
   OR shift_start > shift_end;

---------------------------------------------------
-- REMOVE DUPLICATES (EMPLOYEES)
---------------------------------------------------
DELETE FROM validated.employees_validated
WHERE employee_id IN (
    SELECT employee_id FROM (
        SELECT employee_id,
               ROW_NUMBER() OVER (PARTITION BY employee_id ORDER BY join_date DESC) rn
        FROM validated.employees_validated
    ) WHERE rn > 1
);

---------------------------------------------------
-- INVENTORY
---------------------------------------------------
DELETE FROM validated.inventory_validated
WHERE on_hand_qty < 0
   OR reserved_qty < 0;

---------------------------------------------------
-- SKU DUPLICATES
---------------------------------------------------
DELETE FROM validated.inventory_validated
WHERE sku_id IN (
    SELECT sku_id FROM (
        SELECT sku_id,
               ROW_NUMBER() OVER (PARTITION BY sku_id ORDER BY last_restock_date DESC) rn
        FROM validated.inventory_validated
    ) WHERE rn > 1
);

---------------------------------------------------
-- EVENTS
---------------------------------------------------
DELETE FROM validated.events_validated
WHERE event_type NOT IN ('pick','pack','qc','ship')
   OR event_time IS NULL;

---------------------------------------------------
-- REFERENTIAL CHECKS
---------------------------------------------------

-- Events → Orders
DELETE FROM validated.events_validated
WHERE order_id NOT IN (
    SELECT order_id FROM validated.orders_validated
);

-- Events → Employees
DELETE FROM validated.events_validated
WHERE employee_id NOT IN (
    SELECT employee_id FROM validated.employees_validated
);

-- Orders → Customers
DELETE FROM validated.orders_validated
WHERE customer_id NOT IN (
    SELECT customer_id FROM validated.customers_validated
);

---------------------------------------------------
-- TEMPORAL VALIDATION
---------------------------------------------------
DELETE FROM validated.events_validated
WHERE event_time > CURRENT_TIMESTAMP;

---------------------------------------------------
-- VALUE VALIDATION
---------------------------------------------------
DELETE FROM validated.orders_validated
WHERE order_value > 100000;

DELETE FROM validated.inventory_validated
WHERE reserved_qty > on_hand_qty;

---------------------------------------------------
RETURN 'ALL DATA VALIDATED & CLEANED';

END;
$$;


