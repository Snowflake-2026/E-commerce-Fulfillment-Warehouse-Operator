CREATE ROLE MANAGER_ROLE;
CREATE ROLE WORKER_ROLE;
CREATE ROLE QC_ROLE;
CREATE ROLE ADMIN_ROLE;

CREATE OR REPLACE ROW ACCESS POLICY employee_policy
AS (event_type STRING)
RETURNS BOOLEAN ->
CASE
    WHEN CURRENT_ROLE() = 'ADMIN_ROLE' THEN TRUE
    WHEN CURRENT_ROLE() = 'MANAGER_ROLE' THEN TRUE
    WHEN CURRENT_ROLE() = 'QC_ROLE' AND event_type = 'qc' THEN TRUE
    WHEN CURRENT_ROLE() = 'WORKER_ROLE' AND event_type IN ('pick','pack') THEN TRUE
    ELSE FALSE
END;


CREATE OR REPLACE ROW ACCESS POLICY emp_role_policy
AS (event_type STRING)
RETURNS BOOLEAN ->
CASE
    WHEN CURRENT_ROLE() IN ('ADMIN_ROLE','MANAGER_ROLE') THEN TRUE
    WHEN CURRENT_ROLE() = 'QC_ROLE' AND event_type = 'qc' THEN TRUE
    WHEN CURRENT_ROLE() = 'WORKER_ROLE' AND event_type IN ('pick','pack') THEN TRUE
    ELSE FALSE
END;

