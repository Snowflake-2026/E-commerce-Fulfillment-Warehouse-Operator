CREATE SCHEMA  curated;

CREATE OR REPLACE TABLE curated.dim_customers (
    customer_id INT,
    customer_name STRING,
    email STRING,
    phone STRING,
    city STRING,
    state STRING,
    segment STRING,
    start_date DATE,
    end_date DATE,
    current_flag STRING
);

INSERT INTO curated.dim_customers
SELECT 
    customer_id,
    customer_name,
    email,
    phone,
    city,
    state,
    segment,
    CURRENT_DATE,
    NULL,
    'Y'
FROM validated.customers_validated;

CREATE OR REPLACE PROCEDURE curated.sp_scd_customers()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN

-- EXPIRE OLD RECORDS
UPDATE curated.dim_customers tgt
SET 
    end_date = CURRENT_DATE,
    current_flag = 'N'
FROM validated.customers_validated src
WHERE tgt.customer_id = src.customer_id
  AND tgt.current_flag = 'Y'
  AND (
        tgt.email <> src.email OR
        tgt.phone <> src.phone OR
        tgt.city <> src.city OR
        tgt.state <> src.state OR
        tgt.segment <> src.segment
      );

-- INSERT NEW RECORDS
INSERT INTO curated.dim_customers
SELECT 
    src.customer_id,
    src.customer_name,
    src.email,
    src.phone,
    src.city,
    src.state,
    src.segment,
    CURRENT_DATE,
    NULL,
    'Y'
FROM validated.customers_validated src
LEFT JOIN curated.dim_customers tgt
ON src.customer_id = tgt.customer_id
AND tgt.current_flag = 'Y'
WHERE tgt.customer_id IS NULL
   OR (
        tgt.email <> src.email OR
        tgt.phone <> src.phone OR
        tgt.city <> src.city OR
        tgt.state <> src.state OR
        tgt.segment <> src.segment
      );

RETURN 'SCD2 COMPLETED';

END;
$$;

CREATE OR REPLACE TASK curated.scd_task
WAREHOUSE = compute_wh
AFTER validated.clean_task
AS
CALL curated.sp_scd_customers();

