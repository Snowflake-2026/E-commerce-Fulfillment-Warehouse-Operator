CREATE SCHEMA IF NOT EXISTS curated_kpi;
CREATE OR REPLACE TABLE curated_kpi.kpi_sla_score AS
SELECT 
    CURRENT_DATE AS kpi_date,
    COUNT(*) AS total_orders,
    COUNT(CASE WHEN status = 'shipped' THEN 1 END) AS shipped_orders,
    ROUND( COUNT(CASE WHEN status = 'shipped' THEN 1 END) 
        / COUNT(*) * 100, 2
    ) AS sla_percentage
FROM curated.fact_orders;

select * from curated_kpi.kpi_sla_score;
----------------------------------------------------------EMPLOYEE PRODUCTIVITY-----------------------------------------
CREATE OR REPLACE TABLE curated_kpi.kpi_throughput AS
SELECT 
    DATE_TRUNC('hour', event_time) AS event_hour,
    COUNT(*) AS total_events
FROM curated.fact_events
GROUP BY 1;

select * from curated_kpi.kpi_throughput;

--------------------------------------------------INVENTORY AVAILABILITY---------------------------------------

CREATE OR REPLACE TABLE curated_kpi.kpi_inventory_availability AS
SELECT 
    CURRENT_DATE AS kpi_date,
    COUNT(*) AS total_items,
    COUNT(CASE WHEN on_hand_qty >= reserved_qty THEN 1 END) AS available_items,
    ROUND(
        COUNT(CASE WHEN on_hand_qty >= reserved_qty THEN 1 END)
        / COUNT(*) * 100, 2
    ) AS availability_percentage
FROM validated.inventory_validated;

select * from curated_kpi.kpi_inventory_availability;
---------------------------------------------ORDER ANAMOLIE RATE--------------------------------------------
CREATE OR REPLACE TABLE curated_kpi.kpi_anomaly_rate AS
SELECT 
    CURRENT_DATE AS kpi_date,
    COUNT(*) AS total_orders,
    COUNT(CASE 
        WHEN status NOT IN ('shipped','delivered') THEN 1 END) AS anomaly_orders,
    ROUND(
        COUNT(CASE 
            WHEN status NOT IN ('shipped','delivered') THEN 1 END)
        / COUNT(*) * 100, 2
    ) AS anomaly_percentage
FROM curated.fact_orders;





