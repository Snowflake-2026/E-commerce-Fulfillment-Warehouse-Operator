    CURRENT_DATE,
    NULL,
    'Y'
FROM validated.customers_validated;

CREATE OR REPLACE PROCEDURE curated.sp_scd_customers()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN

---------------------------------------------------
-- STEP 0: READ STREAM ONCE + DEDUPLICATE
---------------------------------------------------
CREATE OR REPLACE TEMP TABLE tmp_customers AS
SELECT *
FROM (
    SELECT *,
           ROW_NUMBER() OVER (PARTITION BY customer_id ORDER BY registration_date DESC) rn
    FROM validated.customers_stream_curated
    WHERE METADATA$ACTION = 'INSERT'
)
WHERE rn = 1;

---------------------------------------------------
-- STEP 1: EXPIRE OLD RECORDS
---------------------------------------------------
UPDATE curated.dim_customers tgt
SET 
    end_date = CURRENT_DATE,
    current_flag = 'N'
FROM tmp_customers src
WHERE tgt.customer_id = src.customer_id
  AND tgt.current_flag = 'Y'
  AND (
        tgt.customer_name <> src.customer_name OR
        tgt.email <> src.email OR
        tgt.phone <> src.phone OR
        tgt.city <> src.city OR
        tgt.state <> src.state OR
        tgt.segment <> src.segment
      );

---------------------------------------------------
-- STEP 2: INSERT NEW RECORDS
---------------------------------------------------
INSERT INTO curated.dim_customers
SELECT 
    src.customer_id,
    src.customer_name,
    src.email,
    src.phone,
    src.city,
    src.state,
    src.segment,
    CURRENT_DATE,
    NULL,
    'Y'
FROM tmp_customers src
LEFT JOIN curated.dim_customers tgt
ON src.customer_id = tgt.customer_id
AND tgt.current_flag = 'Y'
WHERE tgt.customer_id IS NULL
   OR (
        tgt.customer_name <> src.customer_name OR
        tgt.email <> src.email OR
        tgt.phone <> src.phone OR
        tgt.city <> src.city OR
        tgt.state <> src.state OR
        tgt.segment <> src.segment
      );

---------------------------------------------------
RETURN 'SCD2 WORKING CORRECTLY';

END;
$$;

CALL curated.sp_scd_customers();



